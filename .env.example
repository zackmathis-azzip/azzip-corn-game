# Environment variables — Azzip Corn Kernel Game

# Database — Turso (production) or local SQLite file (development)
# Production (Vercel): set both Turso variables in the Vercel dashboard.
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Local dev fallback when Turso vars are unset: file at ./data/corn-game.db
# DATABASE_PATH=./data/corn-game.db

# Campaign schedule (ISO 8601)
CAMPAIGN_STARTS_AT=2026-06-01T00:00:00.000Z
CAMPAIGN_ENDS_AT=2026-12-31T23:59:59.999Z

# Optional: pin a specific campaign by ID
# CAMPAIGN_ID=

# Winner fulfillment notification email
FULFILLMENT_EMAIL=zack.mathis@azzippizza.com

# Resend (optional — logs to console + audit_log if unset)
RESEND_API_KEY=
RESEND_FROM=Azzip Corn Game <noreply@azzippizza.com>

# Admin dashboard password (required for /admin)
ADMIN_PASSWORD=change-me-in-production

# Cloudflare Turnstile (optional — skipped if unset)
TURNSTILE_SECRET_KEY=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# Node environment
NODE_ENV=development
