# Environment variables — Azzip Corn Kernel Game

# Database — Turso (production) or local SQLite file (development)
# Production (Vercel): set both Turso variables in the Vercel dashboard.
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Local dev fallback when Turso vars are unset: file at ./data/corn-game.db
# DATABASE_PATH=./data/corn-game.db

# Campaign schedule (ISO 8601)
CAMPAIGN_STARTS_AT=2026-06-01T00:00:00.000Z
CAMPAIGN_ENDS_AT=2026-12-31T23:59:59.999Z

# Optional: pin a specific campaign by ID
# CAMPAIGN_ID=

# Winner fulfillment notification email
FULFILLMENT_EMAIL=zack.mathis@azzippizza.com

# Resend (winner confirmation emails on prize claim)
RESEND_API_KEY=
RESEND_FROM=Azzip Corn Game <noreply@azzippizza.me>
RESEND_REPLY_TO=zack.mathis@azzippizza.com

# Admin dashboard password (required for /admin)
ADMIN_PASSWORD=change-me-in-production

# Cloudflare Turnstile (optional — skipped if unset)
TURNSTILE_SECRET_KEY=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# Node environment
NODE_ENV=development

# QA only — allow unlimited test plays per session (never enable in production)
# Unset = on automatically when running `npm run dev`; set false to disable locally.
# DEV_ALLOW_REPLAY=true
# DEV_ALLOW_REPLAY=false

# Production: minutes before an unclaimed instant win returns to the prize pool (default 30)
# UNCLAIMED_WIN_TIMEOUT_MINUTES=30
